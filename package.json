{
  "name": "openclaw-zalo-connect",
  "version": "3.0.2",
  "description": "Connect OpenClaw to Zalo personal accounts via zca-js",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "author": "tuanminhhole",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuanminhhole/openclaw-zalo-connect.git"
  },
  "bugs": {
    "url": "https://github.com/tuanminhhole/openclaw-zalo-connect/issues"
  },
  "homepage": "https://github.com/tuanminhhole/openclaw-zalo-connect#readme",
  "keywords": [
    "openclaw-channel",
    "openclaw-plugin",
    "openclaw",
    "zalo",
    "chatbot",
    "channel-plugin",
    "zca-js",
    "messaging"
  ],
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.7",
      "minGatewayVersion": "2026.5.7"
    },
    "build": {
      "openclawVersion": "2026.5.7",
      "pluginSdkVersion": "2026.5.7"
    },
    "channel": {
      "id": "zalo-connect",
      "label": "OpenClaw Zalo Connect",
      "selectionLabel": "Zalo Connect Account",
      "blurb": "Zalo personal account messaging via zca-js. 149 actions for DMs, groups, friends, polls, and more.",
      "docsPath": "/channels/zalo-connect",
      "docsLabel": "zalo-connect",
      "aliases": [
        "oz"
      ],
      "order": 86
    },
    "install": {
      "clawhubSpec": "tuanminhhole/openclaw-zalo-connect",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.5.7"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": false
    }
  },
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:openclaw",
    "prepublishOnly": "npm run build && npm run typecheck",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.7"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "image-size": "^2.0.2",
    "jsqr": "^1.4.0",
    "pngjs": "^7.0.0",
    "qrcode-terminal": "^0.12.0",
    "zca-js": "^2.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "sharp": "^0.33.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist",
    "src",
    "docs",
    "openclaw.plugin.json",
    "index.ts",
    "tsconfig.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
